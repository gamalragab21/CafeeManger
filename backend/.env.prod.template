# ─────────────────────────────────────────────────────────
# Production Environment Variables
# Copy this to .env.prod and fill in real values:
#   cp .env.prod.template .env.prod
#
# ⚠️  .env.prod is git-ignored — NEVER commit production secrets
#
# Generate secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=waselak_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=waselak_prod

# ── JWT Authentication (user login/refresh tokens) ─────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
JWT_ISSUER=waselak
JWT_AUDIENCE=waselak-api

# ── Admin JWT (admin dashboard tokens, separate key) ───
ADMIN_JWT_SECRET=CHANGE_ME_DIFFERENT_RANDOM_64_CHAR_STRING

# ── HMAC (request signing) ─────────────────────────────
# MUST match env/release.properties HMAC_SECRET in mobile apps
HMAC_SECRET=CHANGE_ME_MUST_MATCH_MOBILE_RELEASE_PROPERTIES

# ── Admin Account (seeded on first backend startup) ────
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
