{
  "info": {
    "name": "CafeeManger API",
    "description": "Multi-Vendor Store Management System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "vendor_id", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "admin_password", "value": "123456" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health",
        "auth": { "type": "noauth" }
      }
    },
    {
      "name": "Admin (Owner)",
      "description": "Admin/Owner endpoints — password-protected (no JWT needed). Use header X-Admin-Password.",
      "item": [
        {
          "name": "Get All Stores",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/admin/vendors",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ]
          }
        },
        {
          "name": "Get Store by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/admin/vendors/{{vendor_id}}",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ]
          }
        },
        {
          "name": "Update Store (Full Example)",
          "description": "Update any field of any store. All fields are optional — only send what you want to change.",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/admin/vendors/{{vendor_id}}",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Store Name\",\n  \"logo_url\": \"https://example.com/logo.png\",\n  \"address\": \"New Address\",\n  \"contact_phone\": \"+201234567890\",\n  \"wallet_phone\": \"+201234567891\",\n  \"default_delivery_fee\": 15.00,\n  \"store_type\": \"restaurant\",\n  \"enable_tables\": true,\n  \"enable_dine_in\": true,\n  \"enable_delivery\": true,\n  \"digital_menu_url\": \"https://your-server.com/menu/VENDOR_ID\"\n}"
            }
          }
        },
        {
          "name": "Enable/Disable Tables",
          "description": "Toggle tables feature for a store",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/admin/vendors/{{vendor_id}}",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enable_tables\": false\n}"
            }
          }
        },
        {
          "name": "Enable/Disable Dine-In",
          "description": "Toggle dine-in feature for a store",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/admin/vendors/{{vendor_id}}",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enable_dine_in\": false\n}"
            }
          }
        },
        {
          "name": "Enable/Disable Delivery",
          "description": "Toggle delivery feature for a store",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/admin/vendors/{{vendor_id}}",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enable_delivery\": false\n}"
            }
          }
        },
        {
          "name": "Set Digital Menu URL",
          "description": "Set or update the digital menu URL for a store",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/admin/vendors/{{vendor_id}}",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"digital_menu_url\": \"https://your-server.com/menu/VENDOR_ID\"\n}"
            }
          }
        },
        {
          "name": "Set Store Logo",
          "description": "Set or update the store logo URL",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/admin/vendors/{{vendor_id}}",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"logo_url\": \"https://example.com/store-logo.png\"\n}"
            }
          }
        },
        {
          "name": "Set Store Type",
          "description": "Set the store type (e.g. restaurant, grocery, pharmacy, retail)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/admin/vendors/{{vendor_id}}",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"store_type\": \"grocery\"\n}"
            }
          }
        },
        {
          "name": "Delivery-Only Store Setup",
          "description": "Configure a store for delivery-only (disable tables and dine-in)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/admin/vendors/{{vendor_id}}",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Password", "value": "{{admin_password}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enable_tables\": false,\n  \"enable_dine_in\": false,\n  \"enable_delivery\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Store (Create Manager)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('access_token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);",
                  "pm.collectionVariables.set('vendor_id', jsonData.user.vendor_id);",
                  "pm.collectionVariables.set('user_id', jsonData.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vendor_name\": \"My Store\",\n  \"vendor_address\": \"123 Main St, City\",\n  \"vendor_phone\": \"+201234567890\",\n  \"manager_name\": \"Ahmed Manager\",\n  \"manager_phone\": \"+201111111111\",\n  \"manager_email\": \"ahmed@mystore.com\",\n  \"password\": \"password123\",\n  \"store_type\": \"restaurant\",\n  \"enable_tables\": true,\n  \"enable_dine_in\": true,\n  \"enable_delivery\": true\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('access_token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);",
                  "pm.collectionVariables.set('vendor_id', jsonData.user.vendor_id);",
                  "pm.collectionVariables.set('user_id', jsonData.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+201111111111\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('access_token', jsonData.access_token);",
                  "pm.collectionVariables.set('refresh_token', jsonData.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Vendor (Store Profile)",
      "item": [
        {
          "name": "Get My Store",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/vendors/me"
          }
        },
        {
          "name": "Update My Store",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/vendors/me",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Updated Store\",\n  \"logo_url\": \"https://example.com/logo.png\",\n  \"address\": \"456 New St, City\",\n  \"contact_phone\": \"+201234567890\",\n  \"wallet_phone\": \"+201234567891\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users (Manager Only)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users"
          }
        },
        {
          "name": "Get Users by Role",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users?role=CASHIER",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users"],
              "query": [{ "key": "role", "value": "CASHIER" }]
            }
          }
        },
        {
          "name": "Create Cashier",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"CASHIER\",\n  \"name\": \"Sara Cashier\",\n  \"phone\": \"+201222222222\",\n  \"email\": \"sara@mystore.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Create Delivery User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"DELIVERY\",\n  \"name\": \"Omar Delivery\",\n  \"phone\": \"+201333333333\",\n  \"email\": \"omar@mystore.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/users/{{user_id}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"active\": true\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/categories"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/categories",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hot Drinks\",\n  \"display_order\": 1\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/categories/CATEGORY_ID_HERE",
