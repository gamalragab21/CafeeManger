    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/analytics/summary?from=1704067200000&to=1735689600000",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analytics", "summary"],
              "query": [
                { "key": "from", "value": "1704067200000" },
                { "key": "to", "value": "1735689600000" }
              ]
            }
          }
        },
        {
          "name": "Get Daily Analytics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/analytics/daily?from=1704067200000&to=1735689600000",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analytics", "daily"],
              "query": [
                { "key": "from", "value": "1704067200000" },
                { "key": "to", "value": "1735689600000" }
              ]
            }
          }
        }
      ]
    }
  ]
}
