            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": \"CATEGORY_ID_HERE\",\n  \"name\": \"Cappuccino\",\n  \"description\": \"Hot cappuccino with foam\",\n  \"price\": 35.00,\n  \"available\": true\n}"
